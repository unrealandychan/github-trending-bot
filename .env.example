# ==============================================================================
# GitHub Trending Bot Environment Configuration Template
# Copy this file to '.env' and fill in your private API tokens.
# ==============================================================================

# Notion API Integrations
# ------------------------------------------------------------------------------
# Your Notion integration secret token (starts with ntn_...)
NOTION_API_KEY=your_notion_api_key_here
# The ID of the Notion database to publish trending pages to.
# Database ID is the 32-character string in your database URL:
# https://www.notion.so/workspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=your_notion_database_id_here

# Search API (Optional)
# ------------------------------------------------------------------------------
# Tavily API key for gathering deep search context about repositories.
# If omitted, the bot falls back to standard repository meta-descriptions.
TAVILY_API_KEY=your_tavily_api_key_here

# LLM Providers (At least one is required)
# ------------------------------------------------------------------------------
# The LLM provider to use for report generation ('gemini' or 'openai')
LLM_PROVIDER=gemini

# Google Gemini API configurations (Recommended default)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API configurations (Fallback alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Report Customization
# ------------------------------------------------------------------------------
# The target language for the trending summaries and analysis.
# Supports 'English', 'Traditional Chinese', 'Cantonese', 'Spanish', etc.
# Default: English
REPORT_LANGUAGE=English

# Telegram Notifications (Optional)
# ------------------------------------------------------------------------------
# Your custom Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# The target chat ID, user ID, or channel ID to receive alerts.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# System Configurations (Optional)
# ------------------------------------------------------------------------------
# Absolute or relative path to store history tracking seen repositories.
# HISTORY_FILE_PATH=~/.hermes/scripts/github_trending_seen.json
